# Copy to .env and fill in. NEVER commit .env or paste secrets in chat.
# Values must be clean KEY=VALUE (no inline comments — env_file would fold a
# trailing comment into the value).

# --- Cursor SDK (LLM engine) ---
# CURSOR_API_KEY (SECRET): user/service-account key (NOT a Team Admin key)
CURSOR_API_KEY=
# CURSOR_SDK_MODEL: vision-capable default
CURSOR_SDK_MODEL=composer-2.5
CURSOR_SDK_WORKSPACE=/data/cursor-agent
CURSOR_API_BASE=https://api.cursor.com
# CURSOR_AGENT_MAX_TOOLS: per-turn tool-call cap (runaway guard)
CURSOR_AGENT_MAX_TOOLS=40
# CURSOR_AGENT_MAX_SECONDS: per-turn wall-clock cap
CURSOR_AGENT_MAX_SECONDS=120

# --- Microsoft Teams bot (Entra / Bot Framework) ---
MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD is a SECRET (Entra client secret)
MICROSOFT_APP_PASSWORD=
# MICROSOFT_APP_TYPE: SingleTenant | MultiTenant
MICROSOFT_APP_TYPE=SingleTenant
# MICROSOFT_APP_TENANT_ID: Niteco M365 tenant id (required for SingleTenant)
MICROSOFT_APP_TENANT_ID=
# BOT_HANDLE: the @mention name to strip from inbound text
BOT_HANDLE=chiatienan

# --- Storage ---
# DATABASE_URL: absolute path on the mounted volume
DATABASE_URL=sqlite:////data/chiatienan.db
TZ=Asia/Ho_Chi_Minh

# --- Admin roster page ---
# ADMIN_PASSWORD (SECRET; you choose it): guards /admin and /internal/bridge-smoke
ADMIN_PASSWORD=

# --- VietQR image service ---
# QR_BASE_URL: {base}/{bank}-{account}-{template}.png
QR_BASE_URL=https://img.vietqr.io/image
# QR_TEMPLATE: compact | compact2 | qr_only | print
QR_TEMPLATE=compact2

# --- Deploy (Caddy auto-TLS) ---
# CADDY_DOMAIN: your domain; Caddy issues TLS for it
CADDY_DOMAIN=chiatienan.example.com
