# Copy to .env on the droplet and fill in. NEVER commit .env or paste secrets in chat.
# Values must be clean KEY=VALUE (no inline comments — env_file would swallow them).

# --- Deploy / TLS ---
# CADDY_DOMAIN: your domain; Caddy issues TLS for it
CADDY_DOMAIN=chiatienan.example.duckdns.org

# --- Cursor SDK ---
# CURSOR_API_KEY (SECRET): user/service-account key (NOT a Team Admin key)
CURSOR_API_KEY=
CURSOR_SDK_MODEL=composer-2.5
CURSOR_SDK_WORKSPACE=/tmp/chiatienan-agent

# --- Admin ---
# ADMIN_PASSWORD (SECRET; you choose it): guards /admin and /internal/bridge-smoke
ADMIN_PASSWORD=

# --- Database ---
# DATABASE_URL: absolute path on the mounted volume
DATABASE_URL=sqlite:////data/chiatienan.db
TZ=Asia/Ho_Chi_Minh

# --- Teams / Entra (added when IT provides them) ---
# MICROSOFT_APP_PASSWORD is a SECRET
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=
# MICROSOFT_APP_TYPE=SingleTenant
# MICROSOFT_APP_TENANT_ID=
