# Copy to .env on the droplet and fill in. NEVER commit .env or paste secrets in chat.

# --- Deploy / TLS ---
CADDY_DOMAIN=chiatienan.example.duckdns.org   # your domain; Caddy issues TLS for it

# --- Cursor SDK (SECRET) ---
CURSOR_API_KEY=                                # user/service-account key (NOT Team Admin)
CURSOR_SDK_MODEL=composer-2.5
CURSOR_SDK_WORKSPACE=/tmp/chiatienan-agent

# --- Admin (SECRET; you choose this) ---
ADMIN_PASSWORD=                                # guards /admin and /internal/bridge-smoke

# --- Database ---
DATABASE_URL=sqlite:////data/chiatienan.db     # absolute path on the mounted volume
TZ=Asia/Ho_Chi_Minh

# --- Teams / Entra (added when IT provides them; SECRET where noted) ---
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=                       # SECRET (Entra client secret)
# MICROSOFT_APP_TYPE=SingleTenant
# MICROSOFT_APP_TENANT_ID=
